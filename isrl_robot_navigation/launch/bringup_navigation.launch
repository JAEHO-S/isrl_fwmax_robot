<launch>
  <!-- 지도 -->
  <!-- <node pkg="map_server" type="map_server" name="map_server" args="$(find isrl_robot_navigation)/maps/kindergarden.yaml"/> -->
  <node pkg="map_server" type="map_server" name="map_server" args="$(find isrl_robot_navigation)/maps/argri.yaml"/>
  
  <node pkg="robot_localization" type="ekf_localization_node" name="ekf_odom" output="screen">
    <param name="odom_frame" value="odom"/>
    <param name="base_link_frame" value="mobile_base_link"/>
    <param name="world_frame" value="odom"/>
    <param name="publish_tf" value="false"/>
    <rosparam command="load" file="$(find isrl_robot_navigation)/param/ekf.yaml"/>
  </node>

  <!-- TF 체인: map -> odom 은 AMCL이 퍼블리시, odom -> mobile_base_link 는 로봇이 퍼블리시 -->
  <!-- RViz Fixed Frame은 map 권장 -->

  <!-- AMCL -->
  <node pkg="amcl" type="amcl" name="amcl" output="screen">
    <!-- 프레임 -->
    <param name="base_frame_id" value="mobile_base_link"/>
    <param name="odom_frame_id" value="odom"/>
    <param name="global_frame_id" value="map"/>

    <!-- 파라미터 파일 로드 -->
    <rosparam file="$(find isrl_robot_navigation)/param/amcl.yaml" command="load"/>

    <!-- LaserScan을 쓸 경우 -->
    <remap from="scan" to="/ouster/scan"/>

    <!-- PointCloud2를 레이저처럼 사용할 경우(amlc는 LaserScan 입력을 권장) -->
    <!-- 필요시 pointcloud_to_laserscan 노드로 변환해 /scan 제공 -->
  </node>

  <!-- move_base -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <rosparam file="$(find isrl_robot_navigation)/param/move_base.yaml" command="load"/>
    <rosparam file="$(find isrl_robot_navigation)/param/global_costmap.yaml" command="load"/>
    <rosparam file="$(find isrl_robot_navigation)/param/local_costmap.yaml"  command="load"/>
    <!-- <rosparam file="$(find isrl_robot_navigation)/param/dwa_param.yaml" command="load"/> -->
    <rosparam file="$(find isrl_robot_navigation)/param/teb_local_planner.yaml" command="load"/>


    <remap from="cmd_vel" to="/mobile_robot/cmd_vel"/>
    <remap from="odom" to="/mobile_robot/odom"/>
    
  </node>

  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find isrl_robot_navigation)/rviz/nav.rviz"/>
</launch>
